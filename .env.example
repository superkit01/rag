# =============================================================================
# 基础环境
# =============================================================================
APP_NAME=Enterprise RAG Knowledge Hub
APP_ENV=development
API_PREFIX=/api
DATABASE_URL=postgresql+psycopg://rag:rag@localhost:5432/rag

# =============================================================================
# 工作流后端
# -----------------------------------------------------------------------------
# WORKFLOW_BACKEND=temporal  真实 Temporal，标准联调/部署推荐
#   依赖：TEMPORAL_HOST、TEMPORAL_NAMESPACE、TEMPORAL_TASK_QUEUE
# WORKFLOW_BACKEND=immediate 轻量本地开发/测试，API 进程内直接执行任务
#   依赖：无 Temporal 依赖
# =============================================================================
WORKFLOW_BACKEND=temporal
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=rag-jobs
# 可选：Temporal 启动较慢时调整重试次数
TEMPORAL_CONNECT_RETRIES=20
# 可选：Temporal 连接重试间隔
TEMPORAL_CONNECT_DELAY_SECONDS=1.0

# =============================================================================
# 检索后端
# -----------------------------------------------------------------------------
# SEARCH_BACKEND=opensearch 使用 OpenSearch，适合 Docker/标准联调
#   依赖：OPENSEARCH_URL、OPENSEARCH_INDEX
# SEARCH_BACKEND=memory     使用进程内检索，适合轻量本地开发/测试
#   依赖：无 OpenSearch 依赖；重启进程会从数据库 bootstrap
# =============================================================================
SEARCH_BACKEND=opensearch
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_INDEX=rag_chunks

# =============================================================================
# 检索与问答参数
# -----------------------------------------------------------------------------
# RETRIEVAL_TOP_K：检索候选召回数量
# RERANK_TOP_K：rerank 后送入回答生成和引用构建的候选数量
# CHAT_CONTEXT_TURN_LIMIT：多轮问答时用于 query rewrite 的历史轮数
# =============================================================================
RETRIEVAL_TOP_K=50
RERANK_TOP_K=8
CHAT_CONTEXT_TURN_LIMIT=5

# =============================================================================
# Embedding 后端
# -----------------------------------------------------------------------------
# EMBEDDING_BACKEND=hash   本地伪向量，不需要外部模型，适合本地开发/测试
#   依赖：EMBEDDING_DIMENSIONS
# EMBEDDING_BACKEND=openai OpenAI-compatible embeddings
#   依赖：OPENAI_BASE_URL、OPENAI_API_KEY、OPENAI_EMBEDDING_MODEL
#   影响：最终 chunk 入库向量、检索向量、rerank 向量；切换后建议重建索引
# =============================================================================
EMBEDDING_BACKEND=hash
EMBEDDING_DIMENSIONS=128

# =============================================================================
# 文档切片策略
# -----------------------------------------------------------------------------
# CHUNKING_STRATEGY=fixed-size
#   说明：固定窗口切片
#   依赖配置：CHUNK_SIZE、CHUNK_OVERLAP
#
# CHUNKING_STRATEGY=parent-child
#   说明：大 parent 用于回答上下文，小 child 用于检索召回
#   依赖配置：PARENT_CHUNK_SIZE、PARENT_CHUNK_OVERLAP、
#             CHILD_CHUNK_SIZE、CHILD_CHUNK_OVERLAP
#   注意：parent 落库但不生成 embedding、不入搜索索引；child 入索引
#
# CHUNKING_STRATEGY=semantic
#   说明：使用 sliding window embedding 相似度寻找语义边界
#   依赖配置：SEMANTIC_CHUNK_MAX_SIZE、SEMANTIC_SIMILARITY_THRESHOLD、
#             SLIDING_WINDOW_SIZE、SLIDING_OVERLAP_RATIO
#   若 EMBEDDING_BACKEND=hash：
#     使用本地 hash embedding 做边界判断，不需要模型配置
#   若 EMBEDDING_BACKEND=openai：
#     语义边界判断依赖 SEMANTIC_EMBEDDING_MODEL；
#     最终 chunk 入库/检索 embedding 仍依赖 OPENAI_EMBEDDING_MODEL
#   注意：切换切片策略后，历史文档需要重建索引才会重新切片
# =============================================================================
CHUNKING_STRATEGY=fixed-size

# fixed-size 策略参数
CHUNK_SIZE=700
CHUNK_OVERLAP=100

# parent-child 策略参数
PARENT_CHUNK_SIZE=900
PARENT_CHUNK_OVERLAP=150
CHILD_CHUNK_SIZE=250
CHILD_CHUNK_OVERLAP=50

# semantic 策略参数
SEMANTIC_CHUNK_MAX_SIZE=500
SEMANTIC_SIMILARITY_THRESHOLD=0.75
# 仅在 CHUNKING_STRATEGY=semantic 且 EMBEDDING_BACKEND=openai 时用于语义边界判断
SEMANTIC_EMBEDDING_MODEL=text-embedding-3-small
SLIDING_WINDOW_SIZE=300
SLIDING_OVERLAP_RATIO=0.3

# =============================================================================
# 预留/实验性切片配置
# -----------------------------------------------------------------------------
# 当前主流程尚未完整接入这些策略参数，保留给后续 recursive/hybrid/HyDE 等能力。
# =============================================================================
SLIDING_MERGE_THRESHOLD=0.8
HYPOTHETICAL_QUESTIONS_PER_CHUNK=3
QUESTION_GENERATION_MODEL=gpt-4o-mini
RECURSIVE_SEPARATORS=\n\n,\n,., 
RECURSIVE_MAX_CHUNK_SIZE=800
HYBRID_PRIMARY_STRATEGY=parent-child
HYBRID_SECONDARY_STRATEGY=semantic

# =============================================================================
# Redis
# =============================================================================
# 可选：当前主要预留给缓存/限流，未启用相关能力时可不改
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# 对象存储
# -----------------------------------------------------------------------------
# OBJECT_STORAGE_BACKEND=minio 使用 MinIO
#   依赖：OBJECT_STORAGE_ENDPOINT、OBJECT_STORAGE_BUCKET、
#         OBJECT_STORAGE_ACCESS_KEY、OBJECT_STORAGE_SECRET_KEY
# OBJECT_STORAGE_BACKEND=local 使用本地目录保存上传原始文件
#   依赖：OBJECT_STORAGE_LOCAL_ROOT
# =============================================================================
OBJECT_STORAGE_BACKEND=minio
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_BUCKET=rag-documents
OBJECT_STORAGE_ACCESS_KEY=minioadmin
OBJECT_STORAGE_SECRET_KEY=minioadmin
# 可选：OBJECT_STORAGE_BACKEND=local 时用于保存上传文件
OBJECT_STORAGE_LOCAL_ROOT=./data/object_storage

# =============================================================================
# OpenAI-compatible 模型
# -----------------------------------------------------------------------------
# Chat 生成：
#   启用条件：OPENAI_API_KEY 非空 且 OPENAI_CHAT_MODEL 非空
#
# Embedding：
#   启用条件：EMBEDDING_BACKEND=openai
#   必填：OPENAI_API_KEY、OPENAI_BASE_URL、OPENAI_EMBEDDING_MODEL
#
# Semantic 切片边界判断：
#   启用条件：CHUNKING_STRATEGY=semantic 且 EMBEDDING_BACKEND=openai
#   必填：SEMANTIC_EMBEDDING_MODEL
# =============================================================================
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=
OPENAI_EMBEDDING_MODEL=
OPENAI_EMBEDDING_BATCH_SIZE=10

# =============================================================================
# 前端
# =============================================================================
# 可选：前端 API 地址非默认值时修改
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
