APP_ENV=development
DATABASE_URL=postgresql+psycopg://rag:rag@localhost:5432/rag
# 可切换：temporal 使用真实 Temporal；immediate 用于轻量本地开发和测试
WORKFLOW_BACKEND=temporal
# 可切换：opensearch 使用 OpenSearch；memory 使用进程内检索
SEARCH_BACKEND=opensearch
# 可切换：hash 使用本地伪向量；openai 使用 OpenAI-compatible embeddings
EMBEDDING_BACKEND=hash
# 可切换：fixed-size 使用固定窗口；parent-child 使用小块检索、大块生成
CHUNKING_STRATEGY=fixed-size
# fixed-size 策略
CHUNK_SIZE=700
CHUNK_OVERLAP=100
# parent-child 策略
PARENT_CHUNK_SIZE=900
PARENT_CHUNK_OVERLAP=150
CHILD_CHUNK_SIZE=250
CHILD_CHUNK_OVERLAP=50
# 未来策略预留配置
SEMANTIC_CHUNK_MAX_SIZE=500
SEMANTIC_SIMILARITY_THRESHOLD=0.75
SEMANTIC_EMBEDDING_MODEL=text-embedding-3-small
SLIDING_WINDOW_SIZE=300
SLIDING_OVERLAP_RATIO=0.3
SLIDING_MERGE_THRESHOLD=0.8
HYPOTHETICAL_QUESTIONS_PER_CHUNK=3
QUESTION_GENERATION_MODEL=gpt-4o-mini
RECURSIVE_SEPARATORS=\n\n,\n,., 
RECURSIVE_MAX_CHUNK_SIZE=800
HYBRID_PRIMARY_STRATEGY=parent-child
HYBRID_SECONDARY_STRATEGY=semantic
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_INDEX=rag_chunks
# 可选：当前主要预留给缓存/限流，未启用相关能力时可不改
REDIS_URL=redis://localhost:6379/0
# 可切换：minio 使用 MinIO；local 使用本地目录映射
OBJECT_STORAGE_BACKEND=minio
OBJECT_STORAGE_ENDPOINT=http://localhost:9000
OBJECT_STORAGE_BUCKET=rag-documents
OBJECT_STORAGE_ACCESS_KEY=minioadmin
OBJECT_STORAGE_SECRET_KEY=minioadmin
# 可选：OBJECT_STORAGE_BACKEND=local 时用于保存上传文件
OBJECT_STORAGE_LOCAL_ROOT=./data/object_storage
# 可选：启用 OpenAI-compatible 模型时配置
OPENAI_BASE_URL=https://api.openai.com/v1
# 可选：启用 OpenAI-compatible embeddings 或 chat 时配置
OPENAI_API_KEY=
# 可选：配置后问答生成使用 OpenAI-compatible chat
OPENAI_CHAT_MODEL=
# 可选：EMBEDDING_BACKEND=openai 时必填
OPENAI_EMBEDDING_MODEL=
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=rag-jobs
# 可选：Temporal 启动较慢时调整重试次数
TEMPORAL_CONNECT_RETRIES=20
# 可选：Temporal 连接重试间隔
TEMPORAL_CONNECT_DELAY_SECONDS=1.0
# 可选：前端 API 地址非默认值时修改
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api
